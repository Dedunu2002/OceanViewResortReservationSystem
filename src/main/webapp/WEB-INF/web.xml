<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>Ocean View Resort Reservation System</display-name>

    <servlet>
        <servlet-name>BookingServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.BookingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookingServlet</servlet-name>
        <url-pattern>/booking</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewReservationsServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.ViewReservationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewReservationsServlet</servlet-name>
        <url-pattern>/view-reservations</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteReservationServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.DeleteReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteReservationServlet</servlet-name>
        <url-pattern>/delete-reservation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditReservationServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.EditReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditReservationServlet</servlet-name>
        <url-pattern>/edit-reservation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateReservationServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.UpdateReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateReservationServlet</servlet-name>
        <url-pattern>/update-reservation</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>DailySummaryServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.DailySummaryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DailySummaryServlet</servlet-name>
        <url-pattern>/daily-summary</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddStaffServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.AddStaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddStaffServlet</servlet-name>
        <url-pattern>/AddStaffServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteStaffServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.DeleteStaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteStaffServlet</servlet-name>
        <url-pattern>/DeleteStaffServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RoomStatusServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.RoomStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RoomStatusServlet</servlet-name>
        <url-pattern>/room-status</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateRatesServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.UpdateRatesServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UpdateRatesServlet</servlet-name>
        <url-pattern>/UpdateRatesServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StaffApiServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.StaffApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StaffApiServlet</servlet-name>
        <url-pattern>/api/staff-list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardApiServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.DashboardApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardApiServlet</servlet-name>
        <url-pattern>/api/dashboard-stats</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReceptionApiServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.ReceptionApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReceptionApiServlet</servlet-name>
        <url-pattern>/api/reception-stats</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetBillServlet</servlet-name>
        <servlet-class>com.oceanview.resort.servlet.GetBillServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetBillServlet</servlet-name>
        <url-pattern>/api/get-bill</url-pattern>
    </servlet-mapping>










    <welcome-file-list>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>

</web-app>